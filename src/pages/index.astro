---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import FichaCard from '../components/FichaCard.astro';

const rutas = await getCollection('rutas');
const skills = await getCollection('skills');
const ias = await getCollection('ias');
const trucos = await getCollection('trucos');
const ensenanzas = await getCollection('ensenanzas');

// Destacados: unos pocos ítems para mostrar el catálogo.
const destacados = [
  ...ias.slice(0, 2).map((i) => ({ href: `/ias/${i.id}/`, titulo: i.data.titulo, resumen: i.data.resumen, nivel: i.data.nivel, gratis: i.data.gratis, tipo: 'ia', tags: i.data.tags })),
  ...skills.slice(0, 2).map((i) => ({ href: `/skills/${i.id}/`, titulo: i.data.titulo, resumen: i.data.resumen, nivel: i.data.nivel, gratis: i.data.gratis, tipo: 'skill', tags: i.data.tags })),
];
---

<Base titulo="Aprendé IA, gratis y en español">
  <section style="padding:2.5rem 0 2rem">
    <span class="eyebrow">Biblioteca de IA · gratis y en español</span>
    <h1 class="titulo-pag" style="font-size:clamp(2.2rem,5vw,3.4rem);margin-top:1rem;max-width:18ch">
      Dominá la frontera de la inteligencia artificial
    </h1>
    <p class="sub" style="font-size:1.15rem;max-width:62ch;margin-top:0.75rem">
      Una biblioteca interactiva de IAs, herramientas, MCPs, enseñanzas y trucos: qué son,
      cómo se usan, cómo se accede y para qué sirven. Por niveles, de principiante a avanzado.
    </p>
    <p style="display:flex;gap:.75rem;flex-wrap:wrap;margin-top:1.5rem">
      <a class="btn btn-primario" href="/catalogo/?nivel=principiante">Empezar desde cero</a>
      <a class="btn" href="/catalogo/">Ver catálogo completo</a>
    </p>
  </section>

  <section aria-labelledby="h-niveles">
    <h2 id="h-niveles">Elegí tu nivel</h2>
    <div class="puertas">
      <a class="card" href="/catalogo/?nivel=principiante">
        <span class="badge nivel-principiante">principiante</span>
        <strong>Recién empiezo</strong>
        <span style="color:var(--text-soft)">Qué es la IA, qué herramientas existen y cómo dar los primeros pasos.</span>
      </a>
      <a class="card" href="/catalogo/?nivel=intermedio">
        <span class="badge nivel-intermedio">intermedio</span>
        <strong>Ya uso IA</strong>
        <span style="color:var(--text-soft)">Sacarle más jugo: skills, MCPs y casos de uso que quizá no conocés.</span>
      </a>
      <a class="card" href="/catalogo/?nivel=avanzado">
        <span class="badge nivel-avanzado">avanzado</span>
        <strong>Quiero profundizar</strong>
        <span style="color:var(--text-soft)">Integraciones, MCPs y flujos más potentes.</span>
      </a>
    </div>
  </section>

  <section id="rutas" aria-labelledby="h-rutas" style="margin-top:2rem">
    <h2 id="h-rutas">Rutas por meta</h2>
    <p class="sub">Recorridos ordenados para lograr algo concreto, paso a paso.</p>
    {rutas.length === 0 ? (
      <div class="estado-vacio"><p>Todavía no hay rutas publicadas. ¡Pronto!</p></div>
    ) : (
      <div class="grid">
        {rutas.map((r) => (
          <a class="card" href={`/rutas/${r.id}/`}>
            <div class="badges">
              <span class="badge">ruta</span>
              <span class={`badge nivel-${r.data.nivel}`}>{r.data.nivel}</span>
            </div>
            <strong>{r.data.titulo}</strong>
            <span style="color:var(--text-soft)">{r.data.resumen}</span>
            <span style="color:var(--text-soft);margin-top:auto">{r.data.pasos.length} pasos</span>
          </a>
        ))}
      </div>
    )}
  </section>

  <section id="aprender" aria-labelledby="h-aprender" style="margin-top:2rem">
    <h2 id="h-aprender">Enseñanzas: aprendé a automatizar</h2>
    <p class="sub">Tutoriales paso a paso, con comandos para Windows y Mac.</p>
    {ensenanzas.length === 0 ? (
      <div class="estado-vacio"><p>Pronto, tutoriales.</p></div>
    ) : (
      <div class="grid">
        {ensenanzas.map((e) => (
          <a class="card" href={`/ensenanzas/${e.id}/`}>
            <div class="badges">
              <span class="badge">enseñanza</span>
              <span class={`badge nivel-${e.data.nivel}`}>{e.data.nivel}</span>
              {e.data.tiempo && <span class="badge">⏱ {e.data.tiempo}</span>}
            </div>
            <strong>{e.data.titulo}</strong>
            <span style="color:var(--text-soft)">{e.data.resumen}</span>
            <span style="color:var(--text-soft);margin-top:auto">{e.data.pasos.length} pasos</span>
          </a>
        ))}
      </div>
    )}
  </section>

  <section id="prompts-maestros" aria-labelledby="h-prompts" style="margin-top:2rem">
    <h2 id="h-prompts">Aprendé a escribir prompts maestros</h2>
    <p class="sub">
      La estructura que debe tener todo buen prompt, los pasos para crearlo y cómo ajustarlo
      a cada IA (ChatGPT, Claude, Gemini, Grok).
    </p>
    <div class="grid">
      <a class="card" href="/trucos/prompt-maestro-pasos/">
        <div class="badges"><span class="badge">truco</span><span class="badge nivel-intermedio">intermedio</span></div>
        <strong>Cómo crear un prompt maestro (los 6 pasos)</strong>
        <span style="color:var(--text-soft)">Rol, objetivo, contexto, tarea, formato y restricciones.</span>
      </a>
      <a class="card" href="/trucos/prompt-segun-la-ia/">
        <div class="badges"><span class="badge">truco</span><span class="badge nivel-intermedio">intermedio</span></div>
        <strong>Qué debe tener tu prompt según cada IA</strong>
        <span style="color:var(--text-soft)">Énfasis por herramienta: contexto largo, tiempo real, multimodal.</span>
      </a>
      <a class="card" href="/rutas/prompts-maestros/">
        <div class="badges"><span class="badge">ruta</span><span class="badge nivel-intermedio">intermedio</span></div>
        <strong>Ruta: aprender a escribir prompts maestros</strong>
        <span style="color:var(--text-soft)">Recorrido ordenado, de la base al primer caso con Grok.</span>
      </a>
    </div>
  </section>

  <section id="trucos" aria-labelledby="h-trucos" style="margin-top:2rem">
    <h2 id="h-trucos">Trucos</h2>
    <p class="sub">Consejos cortos para sacarle más a la IA.</p>
    {trucos.length === 0 ? (
      <div class="estado-vacio"><p>Pronto más trucos.</p></div>
    ) : (
      <div class="grid">
        {trucos.slice(0, 4).map((t) => (
          <a class="card" href={`/trucos/${t.id}/`}>
            <div class="badges">
              <span class="badge">truco</span>
              <span class={`badge nivel-${t.data.nivel}`}>{t.data.nivel}</span>
            </div>
            <strong>{t.data.titulo}</strong>
            <span style="color:var(--text-soft)">{t.data.resumen}</span>
          </a>
        ))}
      </div>
    )}
    <p style="margin-top:.75rem"><a href="/catalogo/?tipo=truco">Ver todos los trucos →</a></p>
  </section>

  <section aria-labelledby="h-destacados" style="margin-top:2rem">
    <h2 id="h-destacados">Destacados</h2>
    {destacados.length === 0 ? (
      <div class="estado-vacio"><p>Sin contenido todavía.</p></div>
    ) : (
      <div class="grid">{destacados.map((d) => <FichaCard {...d} />)}</div>
    )}
  </section>

  <section class="cta-band">
    <span class="eyebrow" style="background:rgba(6,182,212,0.18);color:#9beaf7">Velocidad intelectual</span>
    <h2 style="font-size:clamp(1.6rem,4vw,2.4rem);margin:1rem 0 .5rem">¿Listo para construir con IA?</h2>
    <p class="sub" style="max-width:52ch;margin:0 auto 1.5rem">
      Explorá el catálogo, seguí una ruta y probá las enseñanzas. Todo gratis, todo en español.
    </p>
    <a class="btn btn-primario" href="/catalogo/" style="background:var(--accent);border-color:var(--accent);color:#06121a">Explorar la biblioteca</a>
  </section>
</Base>
