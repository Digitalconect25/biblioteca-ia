---
// Pasarela hacia Stripe: exige login y agrega client_reference_id + prefilled_email
// para que el webhook pueda asociar la compra a la cuenta del usuario.
export const prerender = false;

const { user } = Astro.locals;
const link =
  import.meta.env.PUBLIC_STRIPE_PAYMENT_LINK ||
  'https://buy.stripe.com/00w9AM9Llcy34JT60t6sw01';

if (!user) {
  return Astro.redirect(
    '/login?redirect=' +
      encodeURIComponent('/guias/codex-de-cero-a-cien/comprar'),
  );
}

const params = new URLSearchParams();
params.set('client_reference_id', user.id);
if (user.email) params.set('prefilled_email', user.email);

return Astro.redirect(`${link}?${params.toString()}`, 302);
---
