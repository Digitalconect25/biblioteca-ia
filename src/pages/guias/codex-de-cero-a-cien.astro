---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const todos = await getCollection('guiasCodex');
const capitulos = todos
  .filter((e) => e.data.tipo === 'capitulo')
  .sort((a, b) => Number(a.data.n) - Number(b.data.n));
const apendices = todos
  .filter((e) => e.data.tipo === 'apendice')
  .sort((a, b) => String(a.data.n).localeCompare(String(b.data.n)));

const ordenPartes = [
  'Mundo Codex',
  'Codex Desktop',
  'Codex Móvil',
  'Codex Web y Cloud',
  'Flujos de Trabajo Reales',
  'Avanzado',
];
const partesMap = new Map<string, typeof capitulos>();
for (const cap of capitulos) {
  const lista = partesMap.get(cap.data.parte) || [];
  lista.push(cap);
  partesMap.set(cap.data.parte, lista);
}
const partes = ordenPartes
  .map((titulo) => ({ titulo, capitulos: partesMap.get(titulo) || [] }))
  .filter((p) => p.capitulos.length > 0);

const totalCapitulos = capitulos.length;
const totalApendices = apendices.length;

const audiencias = [
  { nombre: 'Curiosos y principiantes',
    detalle: 'Escuchaste "agente de IA" y querés entender qué hace Codex sin tecnicismos. Empezá por los capítulos 1 al 4.' },
  { nombre: 'Devs que ya usan Codex a medias',
    detalle: 'Ya lo instalaste pero sentís que estás usando el 20% de lo que puede hacer: desktop, móvil, Cloud, IDE. Capítulos 5 al 14.' },
  { nombre: 'Desarrolladores en flujos reales',
    detalle: 'Querés aprender TDD, refactors grandes, code review y bug fixing con Codex sin perder horas en pruebas y errores. Capítulos 15 al 19.' },
  { nombre: 'Tech leads y equipos',
    detalle: 'Necesitás AGENTS.md, SDK, integraciones, seguridad y costos bajo control para tu equipo o empresa. Capítulos 20 al 25.' },
];
---

