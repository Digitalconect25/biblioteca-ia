---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import CopyButton from '../../components/CopyButton.astro';

export async function getStaticPaths() {
  const items = await getCollection('ensenanzas');
  return items.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const d = item.data;
const desactualizada = d.revisarAntesDe && new Date() > d.revisarAntesDe;
const fmt = (dt: Date) => dt.toLocaleDateString('es', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base titulo={d.titulo} descripcion={d.resumen}>
  <p><a href="/catalogo/?tipo=ensenanza">← Volver a las enseñanzas</a></p>
  <article data-pagefind-body>
    <div class="badges">
      <span class="badge">enseñanza</span>
      <span class={`badge nivel-${d.nivel}`}>{d.nivel}</span>
      {d.herramienta && <span class="badge">{d.herramienta}</span>}
      {d.tiempo && <span class="badge">⏱ {d.tiempo}</span>}
    </div>
    <h1 class="titulo-pag">{d.titulo}</h1>
    <p class="sub">{d.resumen}</p>

    {desactualizada && (
      <p class="aviso-stale">⚠️ Esta enseñanza pasó su fecha de revisión ({fmt(d.revisarAntesDe!)}). Verificá comandos y enlaces.</p>
    )}

    <p>{d.descripcion}</p>

    <div class="grupo-comandos" style="background:var(--bg-soft)">
      <strong>🎯 Qué vas a lograr</strong>
      <p style="margin:.25rem 0 0">{d.objetivo}</p>
    </div>

    {d.requisitos.length > 0 && (
      <>
        <h2>Requisitos</h2>
        <ul>{d.requisitos.map((r) => <li>{r}</li>)}</ul>
      </>
    )}

    <h2>Pasos</h2>
    <ol class="pasos pasos-ensenanza">
      {d.pasos.map((p) => (
        <li>
          <strong>{p.titulo}</strong>
          <p style="margin:.25rem 0">{p.detalle}</p>
          {p.comun && <CopyButton texto={p.comun} etiqueta="🪟🍎 Windows y macOS" />}
          {p.windows && <CopyButton texto={p.windows} etiqueta="🪟 Windows (PowerShell)" />}
          {p.mac && <CopyButton texto={p.mac} etiqueta="🍎 macOS / Linux" />}
        </li>
      ))}
    </ol>

    {d.enlaces.length > 0 && (
      <>
        <h2>Recursos y repos</h2>
        <ul>{d.enlaces.map((e) => <li><a href={e.url} rel="noopener noreferrer" target="_blank">{e.texto}</a></li>)}</ul>
      </>
    )}

    {d.tags.length > 0 && <div class="badges">{d.tags.map((t) => <span class="badge">#{t}</span>)}</div>}
    <p class="sub" style="margin-top:1.5rem">Actualizado: {fmt(d.actualizado)}</p>
  </article>
</Base>

<style>
  ol.pasos-ensenanza > li { margin-bottom: 1.25rem; }
</style>
