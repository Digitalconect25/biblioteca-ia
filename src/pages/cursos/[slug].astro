---
import Base from '../../layouts/Base.astro';
import { getCollection, getEntry, render } from 'astro:content';
import BotonFavorito from '../../components/BotonFavorito.astro';
import examenesData from '../../data/examenes.json';

export async function getStaticPaths() {
  const cursos = await getCollection('cursos');
  return cursos.map((curso) => ({ params: { slug: curso.id }, props: { curso } }));
}

type Pregunta = { p: string; o: string[]; c: number };
const examenes = examenesData as Record<string, { preguntas: Pregunta[] }>;

const colLabel: Record<string, string> = {
  ias: 'IA', skills: 'Herramienta', mcps: 'MCP', trucos: 'Truco', ensenanzas: 'Enseñanza',
};

const { curso } = Astro.props;
const d = curso.data;
const { Content } = await render(curso);

const lecciones = (
  await Promise.all(
    d.lecciones.map(async (l) => {
      const entry = await getEntry(l.col as any, l.id).catch(() => undefined);
      if (!entry) return null;
      return {
        key: `${l.col}/${l.id}`,
        href: `/${l.col}/${l.id}/`,
        titulo: (entry as any).data.titulo,
        tipo: colLabel[l.col],
      };
    })
  )
).filter(Boolean) as { key: string; href: string; titulo: string; tipo: string }[];
const allKeys = JSON.stringify(lecciones.map((l) => l.key));
const examen = examenes[curso.id]?.preguntas ?? [];
const hoy = new Date().toLocaleDateString('es', { year: 'numeric', month: 'long', day: 'numeric' });
const volver = encodeURIComponent(`/cursos/${curso.id}/`);
---

<Base titulo={d.titulo} descripcion={d.resumen}>
  <p><a href="/cursos/">← Todos los cursos</a></p>
  <span class="eyebrow">Curso</span>
  <h1 class="titulo-pag" style="margin-top:1rem">{d.titulo}</h1>
  <p class="sub" style="max-width:62ch">{d.resumen}</p>
  <div class="badges" style="margin:.5rem 0">
    <span class={`badge nivel-${d.nivel}`}>{d.nivel}</span>
    {d.duracion && <span class="badge">⏱ {d.duracion}</span>}
    <span class="badge">{lecciones.length} lecciones</span>
  </div>

  <p>{d.descripcion}</p>
  <div class="prosa"><Content /></div>

  <!-- Gate: hay que iniciar sesión para guardar progreso y obtener el certificado -->
  <div class="gate" id="gate" hidden>
    <h2>Iniciá sesión para empezar</h2>
    <p class="sub" style="margin:0 0 .85rem">Creá tu cuenta gratis o iniciá sesión: así guardamos tu progreso y, al terminar, generás tu certificado a tu nombre.</p>
    <div style="display:flex;gap:.6rem;flex-wrap:wrap">
      <a class="btn btn-primario" href={`/login?redirect=${volver}`}>Iniciar sesión</a>
      <a class="btn" href={`/registro?redirect=${volver}`}>Crear cuenta</a>
    </div>
  </div>

  <!-- Contenido del curso (se revela tras inscribirse) -->
  <div id="curso-contenido" hidden>
    <div data-keys={allKeys} data-curso={d.titulo} data-slug={curso.id} data-examen={examen.length > 0 ? '1' : '0'} id="curso"
         style="border:1px solid var(--border);border-radius:var(--radius-lg);background:var(--card);padding:1.1rem 1.3rem;margin:1.5rem 0">
      <div style="display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap">
        <strong>Hola, <span id="alumno-nombre">alumno</span> · finalización del curso</strong>
        <span id="curso-pct" class="badge">0%</span>
      </div>
      <div class="barra-prog"><span id="curso-bar"></span></div>
      <p class="sub" id="curso-msg" style="margin:.5rem 0 0;font-size:.85rem"></p>
    </div>

    <h2>Lecciones</h2>
    <ul class="lista-estudio">
      {lecciones.map((l, i) => (
        <li>
          <input type="checkbox" id={`chk-${l.key}`} data-key={l.key} />
          <label for={`chk-${l.key}`} style="flex:1">
            <span style="color:var(--text-soft);font-family:var(--font-mono);font-size:.8rem">{String(i + 1).padStart(2, '0')}</span>
            {' '}<a href={l.href}>{l.titulo}</a>
            <span class="item-tipo">{l.tipo}</span>
          </label>
          <BotonFavorito itemKey={l.key} />
        </li>
      ))}
    </ul>

    <!-- Examen (aparece al completar las lecciones) -->
    {examen.length > 0 && (
      <section id="examen" hidden>
        <h2>Examen del curso</h2>
        <p class="sub">Respondé las {examen.length} preguntas. Necesitás 80% para aprobar y desbloquear tu certificado.</p>
        <form id="examen-form">
          {examen.map((q, qi) => (
            <fieldset class="pregunta" data-c={q.c}>
              <legend><strong>{qi + 1}.</strong> {q.p}</legend>
              {q.o.map((op, oi) => (
                <label class="opcion"><input type="radio" name={`q${qi}`} value={String(oi)} /> <span>{op}</span></label>
              ))}
            </fieldset>
          ))}
        </form>
        <div style="display:flex;gap:.6rem;flex-wrap:wrap;margin-top:1rem">
          <button id="examen-corregir" class="btn btn-primario" type="button">Rendir examen</button>
          <button id="examen-reintentar" class="btn" type="button" hidden>Reintentar</button>
        </div>
        <div id="examen-resultado" class="examen-resultado" hidden></div>
      </section>
    )}

    <!-- Certificado (aparece tras aprobar) -->
    <section id="certificado" class="certificado" hidden>
      <div class="cert-inner">
        <img class="cert-logo" src="/logo-academia.svg" alt="Academia de IA ConectaNex" />
        <span class="eyebrow" style="margin:0 auto">Certificado de finalización</span>
        <p class="cert-otorga">Otorgado a</p>
        <p class="cert-nombre" id="cert-nombre">—</p>
        <p class="cert-texto">por completar el curso</p>
        <p class="cert-curso">{d.titulo}</p>
        <div class="cert-qr" id="cert-qr"></div>
        <p class="cert-pie">
          <span>Academia de IA ConectaNex</span>
          <span>{hoy}</span>
        </p>
      </div>
      <button id="cert-print" class="btn btn-primario no-print" style="margin-top:1rem">Imprimir / Guardar PDF</button>
    </section>
  </div>
</Base>

<script>
  import * as qrmod from 'qrcode-generator';
  import { supabaseBrowser } from '../../lib/supabase/client';
  const qrcode = (qrmod as any).default || (qrmod as any);

  (async function () {
    const cont = document.getElementById('curso');
    if (!cont) return;
    const slug = cont.getAttribute('data-slug') || '';
    const cursoTitulo = cont.getAttribute('data-curso') || '';
    const hasExam = cont.getAttribute('data-examen') === '1';

    const gate = document.getElementById('gate');
    const contenido = document.getElementById('curso-contenido');
    const cert = document.getElementById('certificado');
    const examenEl = document.getElementById('examen');
    const boxes = Array.from(
      document.querySelectorAll('input[type=checkbox][data-key]'),
    ) as HTMLInputElement[];
    const keys = boxes.map((b) => b.getAttribute('data-key') as string);

    function qrInto(el: HTMLElement, text: string) {
      try {
        const qr = qrcode(0, 'M'); qr.addData(text); qr.make();
        el.innerHTML = '<img alt="QR de verificación" src="' + qr.createDataURL(4, 8) + '" /><small>Escaneá para verificar</small>';
      } catch (e) {}
    }

    // ¿Hay sesión? Si no, mostramos el gate de login y salimos.
    const { data: { session } } = await supabaseBrowser.auth.getSession();
    if (!session) {
      if (gate) gate.hidden = false;
      if (contenido) contenido.hidden = true;
      return;
    }
    const nombre = (session.user.user_metadata?.nombre as string) || '';

    if (gate) gate.hidden = true;
    if (contenido) contenido.hidden = false;
    const an = document.getElementById('alumno-nombre');
    if (an) an.textContent = (nombre.split(' ')[0]) || 'alumno';

    // Mapear cada lección (ref "col/id") a su uuid en la BD.
    const refToId: Record<string, string> = {};
    const idToRef: Record<string, string> = {};
    const lessonIds: string[] = [];
    const { data: curso } = await supabaseBrowser.from('courses').select('id').eq('slug', slug).single();
    if (curso) {
      const { data: lessons } = await supabaseBrowser.from('lessons').select('id, ref').eq('course_id', curso.id);
      for (const l of lessons ?? []) {
        if (!l.ref) continue;
        refToId[l.ref] = l.id; idToRef[l.id] = l.ref; lessonIds.push(l.id);
      }
    }

    // Lecciones ya completadas por el usuario.
    const doneRefs = new Set<string>();
    if (lessonIds.length) {
      const { data: prog } = await supabaseBrowser
        .from('lesson_progress').select('lesson_id, completada').in('lesson_id', lessonIds);
      for (const p of prog ?? []) if (p.completada && idToRef[p.lesson_id]) doneRefs.add(idToRef[p.lesson_id]);
    }

    // Examen aprobado / certificado emitido.
    let examOk = false;
    let certCodigo: string | null = null;
    if (curso) {
      const { data: crt } = await supabaseBrowser
        .from('certificates').select('codigo').eq('course_id', curso.id).maybeSingle();
      if (crt) { certCodigo = crt.codigo; examOk = true; }
      else {
        const { data: at } = await supabaseBrowser
          .from('exam_attempts').select('aprobado').eq('course_id', curso.id).eq('aprobado', true).limit(1);
        examOk = !!(at && at.length);
      }
    }

    function refresh() {
      const doneL = keys.filter((k) => doneRefs.has(k)).length;
      const leccionesListas = keys.length ? doneL === keys.length : true;
      const unitsTotal = keys.length + (hasExam ? 1 : 0);
      const unitsDone = doneL + (examOk ? 1 : 0);
      const pct = unitsTotal ? Math.round((unitsDone * 100) / unitsTotal) : 0;
      const bar = document.getElementById('curso-bar'); if (bar) bar.style.width = pct + '%';
      const lbl = document.getElementById('curso-pct'); if (lbl) lbl.textContent = pct + '% completado';
      boxes.forEach((b) => { const li = b.closest('li'); if (li) li.classList.toggle('hecho', doneRefs.has(b.getAttribute('data-key') as string)); });

      const msg = document.getElementById('curso-msg');
      if (msg) {
        if (pct === 100) msg.textContent = '✓ Curso finalizado. Tu certificado está abajo.';
        else if (leccionesListas && hasExam && !examOk) msg.textContent = 'Lecciones completas. Aprobá el examen (80%) para finalizar el curso.';
        else msg.textContent = doneL + ' de ' + keys.length + ' lecciones completadas' + (hasExam ? ' · después rendís el examen' : '');
      }

      if (examenEl) examenEl.hidden = !leccionesListas;

      const certListo = hasExam ? examOk : leccionesListas;
      if (cert) {
        cert.hidden = !certListo;
        if (certListo) {
          const cn = document.getElementById('cert-nombre'); if (cn) cn.textContent = nombre || 'Alumno';
          const fecha = new Date().toLocaleDateString('es');
          const url = location.origin + '/verificar/?n=' + encodeURIComponent(nombre) +
            '&c=' + encodeURIComponent(cursoTitulo) + '&f=' + encodeURIComponent(fecha) +
            (certCodigo ? '&codigo=' + encodeURIComponent(certCodigo) : '');
          const qrEl = document.getElementById('cert-qr');
          if (qrEl && !qrEl.getAttribute('data-done')) { qrInto(qrEl, url); qrEl.setAttribute('data-done', '1'); }
        }
      }
    }

    // Progreso por lección → /api/progreso (el user_id lo pone el servidor).
    boxes.forEach((b) => {
      const k = b.getAttribute('data-key') as string;
      b.checked = doneRefs.has(k);
      b.addEventListener('change', async () => {
        const lessonId = refToId[k];
        if (!lessonId) return;
        const marcar = b.checked;
        b.disabled = true;
        try {
          const res = await fetch('/api/progreso', {
            method: 'POST', headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ lesson_id: lessonId, completada: marcar }),
          });
          if (!res.ok) throw new Error();
          if (marcar) doneRefs.add(k); else doneRefs.delete(k);
          refresh();
          document.dispatchEvent(new CustomEvent('progreso-cambio'));
        } catch {
          b.checked = !marcar; // revertir si falló
        } finally {
          b.disabled = false;
        }
      });
    });

    // Examen → /api/examen (se califica en el servidor y emite el certificado).
    const formEx = document.getElementById('examen-form');
    const btnCorregir = document.getElementById('examen-corregir') as HTMLButtonElement | null;
    const btnReintentar = document.getElementById('examen-reintentar') as HTMLButtonElement | null;
    const resEx = document.getElementById('examen-resultado');
    const preguntas = formEx ? Array.from(formEx.querySelectorAll('.pregunta')) : [];

    if (btnCorregir && formEx) btnCorregir.addEventListener('click', async () => {
      const respuestas = preguntas.map((fs) => {
        const sel = fs.querySelector('input[type=radio]:checked') as HTMLInputElement | null;
        return sel ? parseInt(sel.value, 10) : -1;
      });
      btnCorregir.disabled = true; btnCorregir.textContent = 'Corrigiendo…';
      let out: any = null;
      try {
        const res = await fetch('/api/examen', {
          method: 'POST', headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ curso: slug, respuestas }),
        });
        out = await res.json();
        if (!res.ok) out = { error: out?.error };
      } catch { out = { error: 'red' }; }
      btnCorregir.disabled = false; btnCorregir.textContent = 'Rendir examen';

      if (!out || out.error) {
        if (resEx) {
          resEx.hidden = false; resEx.className = 'examen-resultado reprob';
          resEx.innerHTML = '<strong>No se pudo enviar el examen.</strong> Probá de nuevo en un momento.';
        }
        return;
      }

      // Marcado visual por pregunta (sólo UX; la nota la da el servidor).
      preguntas.forEach((fs, i) => {
        const c = parseInt(fs.getAttribute('data-c') || '-1', 10);
        fs.classList.remove('correcta', 'incorrecta');
        fs.classList.add(respuestas[i] === c ? 'correcta' : 'incorrecta');
      });

      const passed = !!out.aprobado;
      if (resEx) {
        resEx.hidden = false;
        resEx.className = 'examen-resultado ' + (passed ? 'aprob' : 'reprob');
        resEx.innerHTML = '<strong>' + (passed ? '¡Aprobaste! 🎉' : 'Todavía no llegás') + '</strong> · ' +
          out.correctas + '/' + out.total + ' (' + out.puntaje + '%). ' +
          (passed ? 'Tu certificado quedó desbloqueado abajo.' : 'Necesitás 80%. Repasá lo marcado en rojo y reintentá.');
      }
      if (passed) {
        examOk = true;
        if (out.certificado) certCodigo = out.certificado.codigo;
        btnCorregir.hidden = true;
        document.dispatchEvent(new CustomEvent('examen-aprobado'));
        refresh();
        if (cert) cert.scrollIntoView({ behavior: 'smooth' });
      }
      if (btnReintentar) btnReintentar.hidden = false;
    });

    if (btnReintentar && formEx) btnReintentar.addEventListener('click', () => {
      (formEx as HTMLFormElement).reset();
      preguntas.forEach((fs) => fs.classList.remove('correcta', 'incorrecta'));
      if (resEx) resEx.hidden = true;
      if (btnCorregir) btnCorregir.hidden = false;
      btnReintentar.hidden = true;
    });

    const pr = document.getElementById('cert-print');
    if (pr) pr.addEventListener('click', () => window.print());

    refresh();
  })();
</script>
