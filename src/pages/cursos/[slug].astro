---
import Base from '../../layouts/Base.astro';
import { getCollection, getEntry, render } from 'astro:content';
import BotonFavorito from '../../components/BotonFavorito.astro';
import examenesData from '../../data/examenes.json';

export async function getStaticPaths() {
  const cursos = await getCollection('cursos');
  return cursos.map((curso) => ({ params: { slug: curso.id }, props: { curso } }));
}

type Pregunta = { p: string; o: string[]; c: number };
const examenes = examenesData as Record<string, { preguntas: Pregunta[] }>;

const colLabel: Record<string, string> = {
  ias: 'IA', skills: 'Herramienta', mcps: 'MCP', trucos: 'Truco', ensenanzas: 'Enseñanza',
};

const { curso } = Astro.props;
const d = curso.data;
const { Content } = await render(curso);

const lecciones = (
  await Promise.all(
    d.lecciones.map(async (l) => {
      const entry = await getEntry(l.col as any, l.id).catch(() => undefined);
      if (!entry) return null;
      return {
        key: `${l.col}/${l.id}`,
        href: `/${l.col}/${l.id}/`,
        titulo: (entry as any).data.titulo,
        tipo: colLabel[l.col],
      };
    })
  )
).filter(Boolean) as { key: string; href: string; titulo: string; tipo: string }[];
const allKeys = JSON.stringify(lecciones.map((l) => l.key));
const examen = examenes[curso.id]?.preguntas ?? [];
const hoy = new Date().toLocaleDateString('es', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base titulo={d.titulo} descripcion={d.resumen}>
  <p><a href="/cursos/">← Todos los cursos</a></p>
  <span class="eyebrow">Curso</span>
  <h1 class="titulo-pag" style="margin-top:1rem">{d.titulo}</h1>
  <p class="sub" style="max-width:62ch">{d.resumen}</p>
  <div class="badges" style="margin:.5rem 0">
    <span class={`badge nivel-${d.nivel}`}>{d.nivel}</span>
    {d.duracion && <span class="badge">⏱ {d.duracion}</span>}
    <span class="badge">{lecciones.length} lecciones</span>
  </div>

  <p>{d.descripcion}</p>
  <div class="prosa"><Content /></div>

  <!-- Gate: hay que inscribirse con nombre y apellido para empezar -->
  <div class="gate" id="gate">
    <h2>Inscribite para empezar</h2>
    <p class="sub" style="margin:0">Ingresá tu nombre y apellido. Con eso arranca el curso y, al terminarlo, generás tu certificado.</p>
    <div class="gate-form">
      <input id="g-nombre" type="text" placeholder="Nombre" autocomplete="given-name" />
      <input id="g-apellido" type="text" placeholder="Apellido" autocomplete="family-name" />
      <button id="g-empezar" class="btn btn-primario" type="button">Empezar el curso</button>
    </div>
    <p id="g-error" class="gate-error" hidden>Completá nombre y apellido para empezar.</p>
  </div>

  <!-- Contenido del curso (se revela tras inscribirse) -->
  <div id="curso-contenido" hidden>
    <div data-keys={allKeys} data-curso={d.titulo} data-slug={curso.id} data-examen={examen.length > 0 ? '1' : '0'} id="curso"
         style="border:1px solid var(--border);border-radius:var(--radius-lg);background:var(--card);padding:1.1rem 1.3rem;margin:1.5rem 0">
      <div style="display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap">
        <strong>Hola, <span id="alumno-nombre">alumno</span> · finalización del curso</strong>
        <span id="curso-pct" class="badge">0%</span>
      </div>
      <div class="barra-prog"><span id="curso-bar"></span></div>
      <p class="sub" id="curso-msg" style="margin:.5rem 0 0;font-size:.85rem"></p>
    </div>

    <h2>Lecciones</h2>
    <ul class="lista-estudio">
      {lecciones.map((l, i) => (
        <li>
          <input type="checkbox" id={`chk-${l.key}`} data-key={l.key} />
          <label for={`chk-${l.key}`} style="flex:1">
            <span style="color:var(--text-soft);font-family:var(--font-mono);font-size:.8rem">{String(i + 1).padStart(2, '0')}</span>
            {' '}<a href={l.href}>{l.titulo}</a>
            <span class="item-tipo">{l.tipo}</span>
          </label>
          <BotonFavorito itemKey={l.key} />
        </li>
      ))}
    </ul>

    <!-- Examen (aparece al completar las lecciones) -->
    {examen.length > 0 && (
      <section id="examen" hidden>
        <h2>Examen del curso</h2>
        <p class="sub">Respondé las {examen.length} preguntas. Necesitás 80% para aprobar y desbloquear tu certificado.</p>
        <form id="examen-form">
          {examen.map((q, qi) => (
            <fieldset class="pregunta" data-c={q.c}>
              <legend><strong>{qi + 1}.</strong> {q.p}</legend>
              {q.o.map((op, oi) => (
                <label class="opcion"><input type="radio" name={`q${qi}`} value={String(oi)} /> <span>{op}</span></label>
              ))}
            </fieldset>
          ))}
        </form>
        <div style="display:flex;gap:.6rem;flex-wrap:wrap;margin-top:1rem">
          <button id="examen-corregir" class="btn btn-primario" type="button">Rendir examen</button>
          <button id="examen-reintentar" class="btn" type="button" hidden>Reintentar</button>
        </div>
        <div id="examen-resultado" class="examen-resultado" hidden></div>
      </section>
    )}

    <!-- Certificado (aparece tras aprobar) -->
    <section id="certificado" class="certificado" hidden>
      <div class="cert-inner">
        <span class="eyebrow" style="margin:0 auto">Certificado de finalización</span>
        <p class="cert-otorga">Otorgado a</p>
        <p class="cert-nombre" id="cert-nombre">—</p>
        <p class="cert-texto">por completar el curso</p>
        <p class="cert-curso">{d.titulo}</p>
        <div class="cert-qr" id="cert-qr"></div>
        <p class="cert-pie">
          <span>Academia de IA ConectaNex</span>
          <span>{hoy}</span>
        </p>
      </div>
      <button id="cert-print" class="btn btn-primario no-print" style="margin-top:1rem">Imprimir / Guardar PDF</button>
    </section>
  </div>
</Base>

<script>
  import * as qrmod from 'qrcode-generator';
  const qrcode = (qrmod as any).default || (qrmod as any);

  (function () {
    var KEY = 'bib-ia-progreso', ALUMNO = 'bib-ia-alumno';
    function load() { try { return JSON.parse(localStorage.getItem(KEY) || '{}'); } catch (e) { return {}; } }
    function save(m: any) { try { localStorage.setItem(KEY, JSON.stringify(m)); } catch (e) {} }
    function loadAlumno() { try { return JSON.parse(localStorage.getItem(ALUMNO) || 'null'); } catch (e) { return null; } }

    var cont = document.getElementById('curso');
    if (!cont) return;
    var keys: string[] = [];
    try { keys = JSON.parse(cont.getAttribute('data-keys') || '[]'); } catch (e) {}
    var cursoTitulo = cont.getAttribute('data-curso') || '';
    var map = load();
    var boxes = ([] as HTMLInputElement[]).slice.call(document.querySelectorAll('input[type=checkbox][data-key]'));
    var gate = document.getElementById('gate');
    var contenido = document.getElementById('curso-contenido');
    var cert = document.getElementById('certificado');
    var examenEl = document.getElementById('examen');
    var slug = cont.getAttribute('data-slug') || '';
    var hasExam = cont.getAttribute('data-examen') === '1';
    var EXKEY = 'bib-ia-examenes';
    function loadEx() { try { return JSON.parse(localStorage.getItem(EXKEY) || '{}'); } catch (e) { return {}; } }
    function saveEx(m: any) { try { localStorage.setItem(EXKEY, JSON.stringify(m)); } catch (e) {} }
    function examAprobado() { var e = loadEx()[slug]; return !!(e && e.passed); }

    function qrInto(el: HTMLElement, text: string) {
      try {
        var qr = qrcode(0, 'M'); qr.addData(text); qr.make();
        el.innerHTML = '<img alt="QR de verificación" src="' + qr.createDataURL(4, 8) + '" /><small>Escaneá para verificar</small>';
      } catch (e) {}
    }

    function nombreCompleto() {
      var a = loadAlumno();
      return a && a.nombre ? (a.nombre + ' ' + (a.apellido || '')).trim() : '';
    }

    function refresh() {
      var doneL = keys.filter(function (k) { return map[k]; }).length;
      var leccionesListas = keys.length ? doneL === keys.length : true;
      var examOk = hasExam ? examAprobado() : false;
      // Finalización = lecciones + examen aprobado (el examen es la unidad final).
      var unitsTotal = keys.length + (hasExam ? 1 : 0);
      var unitsDone = doneL + (examOk ? 1 : 0);
      var pct = unitsTotal ? Math.round((unitsDone * 100) / unitsTotal) : 0;
      var bar = document.getElementById('curso-bar'); if (bar) bar.style.width = pct + '%';
      var lbl = document.getElementById('curso-pct'); if (lbl) lbl.textContent = pct + '% completado';
      boxes.forEach(function (b) { var li = b.closest('li'); if (li) li.classList.toggle('hecho', !!map[b.getAttribute('data-key') as string]); });

      var msg = document.getElementById('curso-msg');
      if (msg) {
        if (pct === 100) msg.textContent = '✓ Curso finalizado. Tu certificado está abajo.';
        else if (leccionesListas && hasExam && !examOk) msg.textContent = 'Lecciones completas. Aprobá el examen (80%) para finalizar el curso.';
        else msg.textContent = doneL + ' de ' + keys.length + ' lecciones completadas' + (hasExam ? ' · después rendís el examen' : '');
      }

      // El examen aparece una vez completaste las lecciones.
      if (examenEl) examenEl.hidden = !leccionesListas;

      // El certificado: si hay examen, exige aprobarlo; si no, basta completar lecciones.
      var certListo = hasExam ? examOk : leccionesListas;
      if (cert) {
        cert.hidden = !certListo;
        if (certListo) {
          var nom = nombreCompleto();
          var cn = document.getElementById('cert-nombre'); if (cn) cn.textContent = nom || 'Alumno';
          var fecha = new Date().toLocaleDateString('es');
          var url = location.origin + '/verificar/?n=' + encodeURIComponent(nom) + '&c=' + encodeURIComponent(cursoTitulo) + '&f=' + encodeURIComponent(fecha);
          var qrEl = document.getElementById('cert-qr'); if (qrEl) qrInto(qrEl, url);
        }
      }
    }

    function mostrarContenido() {
      if (gate) gate.hidden = true;
      if (contenido) contenido.hidden = false;
      var a = loadAlumno();
      var an = document.getElementById('alumno-nombre');
      if (an && a && a.nombre) an.textContent = a.nombre;
      refresh();
    }

    // Estado inicial: ¿ya inscripto?
    var alumno = loadAlumno();
    if (alumno && alumno.nombre && alumno.apellido) {
      mostrarContenido();
    } else if (gate) {
      // prefill si había nombre suelto
      gate.hidden = false;
    }

    // Inscripción
    var btnEmpezar = document.getElementById('g-empezar');
    if (btnEmpezar) btnEmpezar.addEventListener('click', function () {
      var n = (document.getElementById('g-nombre') as HTMLInputElement);
      var ap = (document.getElementById('g-apellido') as HTMLInputElement);
      var err = document.getElementById('g-error');
      if (!n.value.trim() || !ap.value.trim()) { if (err) err.hidden = false; return; }
      if (err) err.hidden = true;
      try { localStorage.setItem(ALUMNO, JSON.stringify({ nombre: n.value.trim(), apellido: ap.value.trim() })); } catch (e) {}
      mostrarContenido();
    });

    // Progreso por lección
    boxes.forEach(function (b) {
      b.checked = !!map[b.getAttribute('data-key') as string];
      b.addEventListener('change', function () {
        map = load();
        var k = b.getAttribute('data-key') as string;
        if (b.checked) map[k] = true; else delete map[k];
        save(map); refresh();
      });
    });

    // Examen: corregir y desbloquear certificado al aprobar (80%)
    var formEx = document.getElementById('examen-form');
    var btnCorregir = document.getElementById('examen-corregir');
    var btnReintentar = document.getElementById('examen-reintentar');
    var resEx = document.getElementById('examen-resultado');
    var preguntas = formEx ? ([] as Element[]).slice.call(formEx.querySelectorAll('.pregunta')) : [];

    if (btnCorregir && formEx) btnCorregir.addEventListener('click', function () {
      var correctas = 0;
      preguntas.forEach(function (fs) {
        var c = parseInt(fs.getAttribute('data-c') || '-1', 10);
        var sel = fs.querySelector('input[type=radio]:checked') as HTMLInputElement | null;
        fs.classList.remove('correcta', 'incorrecta');
        if (!sel) { fs.classList.add('incorrecta'); return; }
        if (parseInt(sel.value, 10) === c) { correctas++; fs.classList.add('correcta'); }
        else fs.classList.add('incorrecta');
      });
      var total = preguntas.length;
      var pct = total ? Math.round((correctas * 100) / total) : 0;
      var passed = pct >= 80;
      if (resEx) {
        resEx.hidden = false;
        resEx.className = 'examen-resultado ' + (passed ? 'aprob' : 'reprob');
        resEx.innerHTML = '<strong>' + (passed ? '¡Aprobaste! 🎉' : 'Todavía no llegás') + '</strong> · ' +
          correctas + '/' + total + ' (' + pct + '%). ' +
          (passed ? 'Tu certificado quedó desbloqueado abajo.' : 'Necesitás 80%. Repasá lo marcado en rojo y reintentá.');
      }
      if (passed) {
        var m = loadEx(); m[slug] = { score: correctas, total: total, passed: true, date: new Date().toISOString() }; saveEx(m);
        if (btnCorregir) (btnCorregir as HTMLElement).hidden = true;
        refresh();
        if (cert) cert.scrollIntoView({ behavior: 'smooth' });
      }
      if (btnReintentar) (btnReintentar as HTMLElement).hidden = false;
    });

    if (btnReintentar && formEx) btnReintentar.addEventListener('click', function () {
      (formEx as HTMLFormElement).reset();
      preguntas.forEach(function (fs) { fs.classList.remove('correcta', 'incorrecta'); });
      if (resEx) resEx.hidden = true;
      if (btnCorregir) (btnCorregir as HTMLElement).hidden = false;
      (btnReintentar as HTMLElement).hidden = true;
    });

    var pr = document.getElementById('cert-print');
    if (pr) pr.addEventListener('click', function () { window.print(); });
  })();
</script>
