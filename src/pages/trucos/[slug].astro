---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import CopyButton from '../../components/CopyButton.astro';
import Comandos from '../../components/Comandos.astro';

export async function getStaticPaths() {
  const items = await getCollection('trucos');
  return items.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const d = item.data;
const { Content } = await render(item);
const desactualizada = d.revisarAntesDe && new Date() > d.revisarAntesDe;
const fmt = (dt: Date) => dt.toLocaleDateString('es', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base titulo={d.titulo} descripcion={d.resumen}>
  <p><a href="/catalogo/?tipo=truco">← Volver a los trucos</a></p>
  <article data-pagefind-body>
    <div class="badges">
      <span class="badge">truco</span>
      <span class={`badge nivel-${d.nivel}`}>{d.nivel}</span>
      {d.herramienta && <span class="badge">{d.herramienta}</span>}
    </div>
    <h1 class="titulo-pag">{d.titulo}</h1>
    <p class="sub">{d.resumen}</p>

    {desactualizada && (
      <p class="aviso-stale">⚠️ Este truco pasó su fecha de revisión ({fmt(d.revisarAntesDe!)}). Puede haber cambiado.</p>
    )}

    <p>{d.descripcion}</p>

    {d.ejemplo && <CopyButton texto={d.ejemplo} etiqueta="Ejemplo" />}
    <Comandos grupos={d.comandos} />

    <div class="prosa"><Content /></div>

    {d.enlaces.length > 0 && (
      <>
        <h2>Más info</h2>
        <ul>{d.enlaces.map((e) => <li><a href={e.url} rel="noopener noreferrer" target="_blank">{e.texto}</a></li>)}</ul>
      </>
    )}

    {d.tags.length > 0 && <div class="badges">{d.tags.map((t) => <span class="badge">#{t}</span>)}</div>}
    <p class="sub" style="margin-top:1.5rem">Actualizado: {fmt(d.actualizado)}</p>
  </article>
</Base>
