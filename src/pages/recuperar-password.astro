---
import Base from '../layouts/Base.astro';

export const prerender = false;
---

<Base titulo="Recuperar contraseña" descripcion="Restablecé la contraseña de tu cuenta de la Academia.">
  <span class="eyebrow">Tu cuenta</span>
  <h1 class="titulo-pag" style="margin-top:1rem">Recuperar contraseña</h1>
  <p class="sub" style="max-width:52ch">Te enviamos un enlace a tu correo para crear una contraseña nueva.</p>

  <form id="form-reset" class="gate-form" style="margin-top:1.25rem;max-width:420px;flex-direction:column;align-items:stretch">
    <input id="email" type="email" placeholder="Tu correo" autocomplete="email" required />
    <button id="btn-reset" class="btn btn-primario" type="submit">Enviar enlace</button>
  </form>
  <p id="reset-error" class="gate-error" hidden></p>

  <div id="reset-ok" class="etapa" hidden style="margin-top:1.25rem;max-width:520px">
    <h2 style="margin-top:0">Revisá tu correo 📬</h2>
    <p class="sub" style="margin:0">Si ese correo tiene una cuenta, te llegó un enlace para crear una contraseña nueva.</p>
  </div>

  <p class="sub" style="margin-top:1.25rem"><a href="/login/">Volver a iniciar sesión</a></p>
</Base>

<script>
  import { supabaseBrowser } from '../lib/supabase/client';

  const form = document.getElementById('form-reset') as HTMLFormElement;
  const errorEl = document.getElementById('reset-error') as HTMLParagraphElement;
  const okEl = document.getElementById('reset-ok') as HTMLDivElement;
  const btn = document.getElementById('btn-reset') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.hidden = true;
    btn.disabled = true;
    btn.textContent = 'Enviando…';

    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const { error } = await supabaseBrowser.auth.resetPasswordForEmail(email, {
      redirectTo: `${window.location.origin}/actualizar-password/`,
    });

    if (error) {
      errorEl.textContent = 'No se pudo enviar el enlace. Probá de nuevo en un momento.';
      errorEl.hidden = false;
      btn.disabled = false;
      btn.textContent = 'Enviar enlace';
      return;
    }
    form.hidden = true;
    okEl.hidden = false;
  });
</script>
