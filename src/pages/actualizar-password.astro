---
import Base from '../layouts/Base.astro';

export const prerender = false;
---

<Base titulo="Nueva contraseña" descripcion="Creá una contraseña nueva para tu cuenta.">
  <span class="eyebrow">Tu cuenta</span>
  <h1 class="titulo-pag" style="margin-top:1rem">Nueva contraseña</h1>

  <p id="reset-cargando" class="sub" style="max-width:52ch">Verificando el enlace…</p>

  <form id="form-nueva" class="gate-form" hidden style="margin-top:1.25rem;max-width:420px;flex-direction:column;align-items:stretch">
    <p class="sub" style="margin:0 0 .25rem">Escribí tu contraseña nueva.</p>
    <input id="password" type="password" placeholder="Contraseña nueva (mínimo 6)" autocomplete="new-password" minlength="6" required />
    <button id="btn-nueva" class="btn btn-primario" type="submit">Guardar contraseña</button>
  </form>

  <p id="nueva-error" class="gate-error" hidden></p>

  <div id="enlace-invalido" class="etapa" hidden style="margin-top:1.25rem;max-width:520px">
    <h2 style="margin-top:0">Enlace inválido o vencido</h2>
    <p class="sub" style="margin:0">Pedí uno nuevo en <a href="/recuperar-password/">Recuperar contraseña</a>.</p>
  </div>

  <div id="nueva-ok" class="etapa" hidden style="margin-top:1.25rem;max-width:520px">
    <h2 style="margin-top:0">¡Contraseña actualizada! ✓</h2>
    <p class="sub" style="margin:0">Ya podés <a href="/dashboard/">ir a tu panel</a>.</p>
  </div>
</Base>

<script>
  import { supabaseBrowser } from '../lib/supabase/client';

  const cargando = document.getElementById('reset-cargando') as HTMLParagraphElement;
  const form = document.getElementById('form-nueva') as HTMLFormElement;
  const errorEl = document.getElementById('nueva-error') as HTMLParagraphElement;
  const invalido = document.getElementById('enlace-invalido') as HTMLDivElement;
  const okEl = document.getElementById('nueva-ok') as HTMLDivElement;
  const btn = document.getElementById('btn-nueva') as HTMLButtonElement;

  // El cliente del navegador detecta el token de recuperación de la URL y crea
  // una sesión temporal. Si llega, mostramos el formulario; si no, el enlace no sirve.
  function mostrarFormulario() {
    cargando.hidden = true;
    invalido.hidden = true;
    form.hidden = false;
  }
  function mostrarInvalido() {
    cargando.hidden = true;
    form.hidden = true;
    invalido.hidden = false;
  }

  supabaseBrowser.auth.onAuthStateChange((event, session) => {
    if (event === 'PASSWORD_RECOVERY' || (event === 'SIGNED_IN' && session)) {
      mostrarFormulario();
    }
  });

  // Respaldo: si ya hay sesión activa (token ya procesado), mostrar el formulario.
  (async () => {
    const { data } = await supabaseBrowser.auth.getSession();
    if (data.session) mostrarFormulario();
    else setTimeout(() => { if (form.hidden) mostrarInvalido(); }, 2500);
  })();

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.hidden = true;
    btn.disabled = true;
    btn.textContent = 'Guardando…';

    const password = (document.getElementById('password') as HTMLInputElement).value;
    const { error } = await supabaseBrowser.auth.updateUser({ password });

    if (error) {
      errorEl.textContent = 'No se pudo actualizar la contraseña. Probá de nuevo.';
      errorEl.hidden = false;
      btn.disabled = false;
      btn.textContent = 'Guardar contraseña';
      return;
    }
    form.hidden = true;
    okEl.hidden = false;
  });
</script>
