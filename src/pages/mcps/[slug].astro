---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import FichaDetalle from '../../components/FichaDetalle.astro';

export async function getStaticPaths() {
  const items = await getCollection('mcps');
  return items.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const d = item.data;
---

<Base titulo={d.titulo} descripcion={d.resumen}>
  <p><a href="/catalogo/">← Volver al catálogo</a></p>
  <FichaDetalle
    tipo="mcp"
    titulo={d.titulo}
    nivel={d.nivel}
    gratis={d.gratis}
    resumen={d.resumen}
    descripcion={d.descripcion}
    accionTitulo="Cómo conectar"
    accionTexto={d.comoConectar}
    comandos={d.comandos}
    funciones={d.funciones}
    ejemplo={d.ejemploConfig}
    ejemploTitulo="Configuración de ejemplo"
    enlaces={d.enlaces}
    tags={d.tags}
    actualizado={d.actualizado}
    revisarAntesDe={d.revisarAntesDe}
  />
</Base>
