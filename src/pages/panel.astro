---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import examenesData from '../data/examenes.json';

const examenes = examenesData as Record<string, { preguntas: unknown[] }>;
const cursos = (await getCollection('cursos')).sort((a, b) => (a.data.orden ?? 0) - (b.data.orden ?? 0));
const cursosInfo = cursos.map((c) => ({
  id: c.id,
  titulo: c.data.titulo,
  href: `/cursos/${c.id}/`,
  keys: c.data.lecciones.map((l) => `${l.col}/${l.id}`),
  examen: !!examenes[c.id],
}));

// Lookup de todo el contenido para resolver favoritos (key -> titulo + href)
const cols: [string, string][] = [
  ['ias', 'ias'], ['skills', 'skills'], ['mcps', 'mcps'], ['trucos', 'trucos'], ['ensenanzas', 'ensenanzas'],
];
const lookup: Record<string, { t: string; h: string }> = {};
for (const [col] of cols) {
  const entries = await getCollection(col as any);
  for (const e of entries as any[]) {
    lookup[`${col}/${e.id}`] = { t: e.data.titulo, h: `/${col}/${e.id}/` };
  }
}
---

<Base titulo="Mi panel" descripcion="Tu panel de alumno: tus datos, cursos, certificados y favoritos.">
  <span class="eyebrow">Mi panel</span>
  <h1 class="titulo-pag" style="margin-top:1rem">Panel del alumno</h1>
  <p class="sub" style="max-width:62ch">Todo tu progreso vive en este navegador, sin cuenta. Registrate con tu nombre y apellido (van en tu diploma): cada alumno tiene su propio avance y podés cambiar de alumno cuando quieras.</p>

  <!-- Nivel y logros -->
  <section class="gami-card" style="margin-top:1.25rem">
    <div class="gami-top">
      <div>
        <span class="gami-rank">Nivel: <span id="g-rank">Novato</span></span>
        <div class="gami-xp" id="g-xp">0 XP</div>
      </div>
      <div class="gami-racha" id="g-racha">🔥 0 días de racha</div>
    </div>
    <div class="barra-prog" style="margin:.5rem 0 .25rem"><span id="g-bar"></span></div>
    <p class="sub" id="g-next" style="margin:0;font-size:.8rem"></p>
    <div class="logros" id="g-logros"></div>
  </section>

  <!-- Cuenta / alumnos -->
  <section class="etapa" style="margin-top:1.25rem">
    <h2 style="margin-top:0">Tu cuenta</h2>
    <p class="sub" style="margin:0 0 .75rem">Cada alumno tiene su propio progreso. Podés cambiar de alumno o registrar uno nuevo (varios alumnos en este mismo dispositivo).</p>

    <div id="cuenta-activa" hidden>
      <p style="margin:0 0 .5rem">Alumno activo: <strong id="activo-nombre">—</strong></p>
      <div style="display:flex;gap:.6rem;align-items:center;flex-wrap:wrap">
        <label class="sub" for="sel-alumno">Cambiar de alumno:</label>
        <select id="sel-alumno" style="padding:.5rem;min-height:40px;border-radius:var(--radius);border:1px solid var(--border-strong);background:var(--card);color:var(--text)"></select>
        <button id="btn-nuevo" class="btn" type="button">+ Nuevo alumno</button>
      </div>
      <div style="margin-top:.85rem">
        <p class="sub" style="margin:0 0 .35rem">Editar tu nombre (aparece en el certificado):</p>
        <div class="gate-form" style="margin:0">
          <input id="p-nombre" type="text" placeholder="Nombre" autocomplete="given-name" />
          <input id="p-apellido" type="text" placeholder="Apellido" autocomplete="family-name" />
          <button id="p-guardar" class="btn btn-primario" type="button">Guardar</button>
        </div>
        <span id="p-ok" class="sub" style="color:var(--ok)" hidden>Guardado ✓</span>
      </div>
    </div>

    <div id="cuenta-registro" hidden>
      <p style="margin:0 0 .5rem"><strong>Registrate para empezar</strong></p>
      <div class="gate-form" style="margin:0">
        <input id="r-nombre" type="text" placeholder="Nombre" autocomplete="given-name" />
        <input id="r-apellido" type="text" placeholder="Apellido" autocomplete="family-name" />
        <button id="r-crear" class="btn btn-primario" type="button">Crear alumno</button>
      </div>
      <p id="r-error" class="gate-error" hidden>Completá nombre y apellido.</p>
    </div>
  </section>

  <!-- Resumen -->
  <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(160px,1fr));margin:1.25rem 0">
    <div class="card" style="text-align:center"><strong id="st-fin" style="font-size:2rem">0</strong><span class="sub">cursos finalizados</span></div>
    <div class="card" style="text-align:center"><strong id="st-prog" style="font-size:2rem">0</strong><span class="sub">en progreso</span></div>
    <div class="card" style="text-align:center"><strong id="st-fav" style="font-size:2rem">0</strong><span class="sub">favoritos</span></div>
  </div>

  <!-- Cursos -->
  <h2>Tus cursos</h2>
  <div>
    {cursosInfo.map((c) => (
      <div class="panel-curso" data-keys={JSON.stringify(c.keys)} data-slug={c.id} data-examen={c.examen ? '1' : '0'}
           style="border:1px solid var(--border);border-radius:var(--radius);padding:.85rem 1.1rem;margin-bottom:.6rem">
        <div style="display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;align-items:center">
          <a href={c.href} style="font-weight:600">{c.titulo}</a>
          <span class="badge estado">Sin empezar</span>
        </div>
        <div class="barra-prog" style="margin:.4rem 0 0"><span></span></div>
      </div>
    ))}
  </div>

  <!-- Certificados -->
  <h2 style="margin-top:2rem">Tus certificados</h2>
  <div id="certs" class="grid"></div>
  <p id="certs-vacio" class="sub">Todavía no tenés certificados. Completá un curso (lecciones + examen) para obtener el tuyo.</p>

  <!-- Favoritos -->
  <h2 style="margin-top:2rem">Tus favoritos</h2>
  <div id="favs"></div>
  <p id="favs-vacio" class="sub">Marcá contenidos con ♥ para guardarlos acá.</p>

  <script type="application/json" id="lookup" set:html={JSON.stringify(lookup)}></script>
</Base>

<script is:inline>
  (function () {
    var BIB = window.BIB;
    var prog = BIB.get('progreso', '{}');
    var exam = BIB.get('examenes', '{}');
    var favs = BIB.get('favoritos', '{}');
    var lookup = {}; try { lookup = JSON.parse(document.getElementById('lookup').textContent || '{}'); } catch (e) {}

    // ---- Cuenta / alumnos ----
    function nombreCompleto(s) { return ((s.nombre || '') + ' ' + (s.apellido || '')).trim(); }
    function renderCuenta() {
      var activo = BIB.active();
      var elActiva = document.getElementById('cuenta-activa');
      var elReg = document.getElementById('cuenta-registro');
      if (activo) {
        elActiva.hidden = false; elReg.hidden = true;
        document.getElementById('activo-nombre').textContent = nombreCompleto(activo) || 'Alumno';
        var sel = document.getElementById('sel-alumno'); sel.innerHTML = '';
        BIB.students().forEach(function (s) {
          var o = document.createElement('option'); o.value = s.id; o.textContent = nombreCompleto(s) || s.id;
          if (s.id === BIB.activeId) o.selected = true; sel.appendChild(o);
        });
        var nn = document.getElementById('p-nombre'), aa = document.getElementById('p-apellido');
        if (nn) nn.value = activo.nombre || ''; if (aa) aa.value = activo.apellido || '';
      } else { elActiva.hidden = true; elReg.hidden = false; }
    }
    renderCuenta();

    var sel = document.getElementById('sel-alumno');
    if (sel) sel.addEventListener('change', function () { BIB.setActive(sel.value); location.reload(); });

    var btnNuevo = document.getElementById('btn-nuevo');
    if (btnNuevo) btnNuevo.addEventListener('click', function () {
      document.getElementById('cuenta-activa').hidden = true;
      document.getElementById('cuenta-registro').hidden = false;
      var rn = document.getElementById('r-nombre'); if (rn) rn.focus();
    });

    var rCrear = document.getElementById('r-crear');
    if (rCrear) rCrear.addEventListener('click', function () {
      var rn = document.getElementById('r-nombre'), ra = document.getElementById('r-apellido'), re = document.getElementById('r-error');
      if (!rn.value.trim() || !ra.value.trim()) { if (re) re.hidden = false; return; }
      BIB.register(rn.value.trim(), ra.value.trim()); location.reload();
    });

    var pg = document.getElementById('p-guardar');
    if (pg) pg.addEventListener('click', function () {
      var activo = BIB.active(); if (!activo) return;
      var nn = document.getElementById('p-nombre'), aa = document.getElementById('p-apellido');
      var list = BIB.students();
      for (var i = 0; i < list.length; i++) {
        if (list[i].id === activo.id) { list[i].nombre = (nn.value || '').trim(); list[i].apellido = (aa.value || '').trim(); }
      }
      BIB.saveStudents(list);
      document.getElementById('activo-nombre').textContent = ((nn.value || '') + ' ' + (aa.value || '')).trim();
      if (sel) { var op = sel.querySelector('option[value="' + activo.id + '"]'); if (op) op.textContent = ((nn.value || '') + ' ' + (aa.value || '')).trim(); }
      var ok = document.getElementById('p-ok'); if (ok) { ok.hidden = false; setTimeout(function () { ok.hidden = true; }, 2000); }
    });

    // Cursos + stats + certificados
    var fin = 0, enprog = 0, certs = document.getElementById('certs'), certsVacio = document.getElementById('certs-vacio');
    document.querySelectorAll('.panel-curso').forEach(function (row) {
      var keys = []; try { keys = JSON.parse(row.getAttribute('data-keys') || '[]'); } catch (e) {}
      var hasExam = row.getAttribute('data-examen') === '1';
      var slug = row.getAttribute('data-slug') || '';
      var a = row.querySelector('a'); var titulo = a ? a.textContent : slug; var href = a ? a.getAttribute('href') : '#';
      var doneL = keys.filter(function (k) { return prog[k]; }).length;
      var examOk = hasExam && exam[slug] && exam[slug].passed;
      var unitsTotal = keys.length + (hasExam ? 1 : 0);
      var unitsDone = doneL + (examOk ? 1 : 0);
      var pct = unitsTotal ? Math.round((unitsDone * 100) / unitsTotal) : 0;
      var bar = row.querySelector('.barra-prog > span'); if (bar) bar.style.width = pct + '%';
      var est = row.querySelector('.estado');
      if (pct === 100) { fin++; if (est) { est.textContent = '✓ Finalizado'; est.classList.add('gratis'); }
        if (certs) { var card = document.createElement('a'); card.className = 'card'; card.href = href;
          card.innerHTML = '<div class="badges"><span class="badge gratis">🎓 Certificado</span></div><strong>' + titulo + '</strong><span class="sub">Ver y descargar tu diploma →</span>'; certs.appendChild(card); } }
      else if (pct > 0) { enprog++; if (est) est.textContent = pct + '% · en progreso'; }
      else { if (est) est.textContent = 'Sin empezar'; }
    });
    var f1 = document.getElementById('st-fin'); if (f1) f1.textContent = String(fin);
    var f2 = document.getElementById('st-prog'); if (f2) f2.textContent = String(enprog);
    if (certs && certs.children.length > 0 && certsVacio) certsVacio.hidden = true;

    // Favoritos
    var favKeys = Object.keys(favs).filter(function (k) { return favs[k]; });
    var fav2 = document.getElementById('st-fav'); if (fav2) fav2.textContent = String(favKeys.length);
    var favsEl = document.getElementById('favs'), favsVacio = document.getElementById('favs-vacio');
    if (favKeys.length && favsEl) {
      favsVacio.hidden = true;
      var ul = document.createElement('ul'); ul.className = 'lista-estudio';
      favKeys.forEach(function (k) {
        var info = lookup[k]; var li = document.createElement('li');
        if (info) li.innerHTML = '<span>♥</span> <a href="' + info.h + '">' + info.t + '</a>';
        else li.innerHTML = '<span>♥</span> ' + k;
        ul.appendChild(li);
      });
      favsEl.appendChild(ul);
    }

    // Nivel, XP, racha y logros
    var RANKS = ['Novato', 'Aprendiz', 'Practicante', 'Avanzado', 'Experto', 'Maestro', 'Leyenda IA'];
    var racha = BIB.get('racha', '{}');
    var nProg = Object.keys(prog).filter(function (k) { return prog[k]; }).length;
    var passed = 0, perfect = 0;
    Object.keys(exam).forEach(function (k) { var e = exam[k]; if (e && e.passed) { passed++; if (e.score === e.total) perfect++; } });
    var dias = racha.dias || 0;
    var xp = nProg * 10 + passed * 50 + favKeys.length * 2;
    var nivel = Math.min(Math.floor(xp / 200), RANKS.length - 1);
    var rk = document.getElementById('g-rank'); if (rk) rk.textContent = RANKS[nivel];
    var xpEl = document.getElementById('g-xp'); if (xpEl) xpEl.textContent = xp + ' XP';
    var rEl = document.getElementById('g-racha'); if (rEl) rEl.textContent = '🔥 ' + dias + (dias === 1 ? ' día' : ' días') + ' de racha';
    var bEl = document.getElementById('g-bar'); if (bEl) bEl.style.width = Math.round(((xp - nivel * 200) / 200) * 100) + '%';
    var nx = document.getElementById('g-next');
    if (nx) nx.textContent = nivel < RANKS.length - 1 ? ('Te faltan ' + (200 - (xp - nivel * 200)) + ' XP para ' + RANKS[nivel + 1]) : '¡Nivel máximo! Sos una Leyenda IA.';

    var logros = [
      { n: 'Primeros pasos', i: '🌱', ok: nProg >= 1 },
      { n: 'Curioso', i: '🔎', ok: nProg >= 5 },
      { n: 'Estudioso', i: '📚', ok: nProg >= 15 },
      { n: 'Maestría', i: '🧠', ok: nProg >= 30 },
      { n: 'Primer examen', i: '✅', ok: passed >= 1 },
      { n: 'Nota perfecta', i: '💯', ok: perfect >= 1 },
      { n: 'Graduado', i: '🎓', ok: passed >= 3 },
      { n: 'Fan de la IA', i: '❤️', ok: favKeys.length >= 5 },
      { n: 'En racha', i: '🔥', ok: dias >= 3 },
      { n: 'Imparable', i: '⚡', ok: dias >= 7 }
    ];
    var gl = document.getElementById('g-logros');
    if (gl) logros.forEach(function (l) {
      var d = document.createElement('div'); d.className = 'logro ' + (l.ok ? 'ok' : 'locked');
      d.innerHTML = '<span class="icono">' + l.i + '</span><span class="nombre">' + l.n + '</span>';
      gl.appendChild(d);
    });
  })();
</script>
