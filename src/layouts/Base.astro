---
import '../styles/global.css';

interface Props {
  titulo: string;
  descripcion?: string;
}
const { titulo, descripcion = 'Academia de IA ConectaNex: aprendé inteligencia artificial gratis y en español, de cero a avanzado, con cursos certificados.' } = Astro.props;
const anio = new Date().getFullYear();

const tituloCompleto = `${titulo} · Academia de IA ConectaNex`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/hero-academia.jpg', Astro.site).href;
---

<!doctype html>
<html lang="es" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={descripcion} />
    <title>{tituloCompleto}</title>
    <link rel="canonical" href={canonical} />

    <!-- Open Graph (Facebook, WhatsApp, LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Academia de IA ConectaNex" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:title" content={tituloCompleto} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1500" />
    <meta property="og:image:height" content="1000" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={tituloCompleto} />
    <meta name="twitter:description" content={descripcion} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Datos estructurados: organización y sitio (Schema.org) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'EducationalOrganization',
      name: 'Academia de IA ConectaNex',
      alternateName: 'ConectaNex · Academia de IA',
      url: 'https://academia.conectanex.com',
      logo: 'https://academia.conectanex.com/logo-academia.svg',
      image: ogImage,
      description: 'Academia gratis y en español para aprender inteligencia artificial, de cero a avanzado, con cursos certificados.',
      founder: { '@type': 'Person', name: 'Yinmy Lazaro Carrazana' },
      inLanguage: 'es',
      sameAs: ['https://github.com/Digitalconect25/biblioteca-ia'],
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'Academia de IA ConectaNex',
      url: 'https://academia.conectanex.com',
      inLanguage: 'es',
      potentialAction: {
        '@type': 'SearchAction',
        target: 'https://academia.conectanex.com/catalogo/?q={search_term_string}',
        'query-input': 'required name=search_term_string',
      },
    })} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap"
      rel="stylesheet"
    />
    <!-- Anti-FOUC: aplica el tema guardado antes del primer paint. -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('tema');
          if (!t) {
            t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {}
      })();
    </script>
    <!-- Sistema de alumnos: cada perfil tiene su propio progreso (namespacing en localStorage) -->
    <script is:inline>
      (function () {
        function ls(k) { try { return localStorage.getItem(k); } catch (e) { return null; } }
        function sls(k, v) { try { localStorage.setItem(k, v); } catch (e) {} }
        var BIB = {
          activeId: ls('bib-ia-activo') || '',
          key: function (name) { return this.activeId ? ('bib-ia-u-' + this.activeId + '-' + name) : ('bib-ia-' + name); },
          get: function (name, def) { try { return JSON.parse(ls(this.key(name)) || def); } catch (e) { return JSON.parse(def); } },
          set: function (name, val) { sls(this.key(name), JSON.stringify(val)); },
          remove: function (name) { try { localStorage.removeItem(this.key(name)); } catch (e) {} },
          students: function () { try { return JSON.parse(ls('bib-ia-estudiantes') || '[]'); } catch (e) { return []; } },
          saveStudents: function (a) { sls('bib-ia-estudiantes', JSON.stringify(a)); },
          active: function () { var id = this.activeId; return this.students().filter(function (s) { return s.id === id; })[0] || null; },
          setActive: function (id) { this.activeId = id; sls('bib-ia-activo', id); },
          register: function (nombre, apellido) {
            var list = this.students();
            var id = 'a' + Date.now().toString(36) + Math.random().toString(36).slice(2, 6);
            list.push({ id: id, nombre: nombre, apellido: apellido, creado: new Date().toISOString() });
            this.saveStudents(list); this.setActive(id); return id;
          }
        };
        window.BIB = BIB;
      })();
    </script>
  </head>
  <body>
    <header class="sitio">
      <div class="barra">
        <a class="marca" href="/">🎓 Academia IA <span style="color:var(--text-soft);font-weight:500">· ConectaNex</span></a>
        <nav aria-label="Principal">
          <a href="/cursos/">Cursos</a>
          <a href="/herramientas/">IAs</a>
          <a href="/catalogo/">Catálogo</a>
          <a href="/repos/">Repos</a>
          <a href="/aportar/">Contacto</a>
        </nav>
        <span class="crecer"></span>
        <!-- Estado de sesión: por defecto invitado; el script lo actualiza si hay sesión. -->
        <div id="nav-auth" class="nav-auth">
          <a href="/login/">Iniciar sesión</a>
          <a class="btn btn-primario" href="/registro/">Registrarse</a>
        </div>
        <button id="toggle-tema" class="btn" type="button" aria-label="Cambiar tema claro/oscuro">
          <span aria-hidden="true">🌓</span> Tema
        </button>
      </div>
    </header>

    <main class="contenedor" style="padding-top:1.5rem">
      <slot />
    </main>

    <footer class="sitio">
      <div class="footer-cols">
        <div>
          <a class="marca" href="/">🎓 Academia IA · ConectaNex</a>
          <p class="sub" style="margin:.5rem 0 0;max-width:34ch">Aprendé inteligencia artificial gratis y en español, de cero a avanzado.</p>
        </div>
        <nav aria-label="Academia">
          <strong>Academia</strong>
          <a href="/cursos/">Cursos</a>
          <a href="/estudiar/">Plan de estudio</a>
          <a href="/catalogo/">Catálogo</a>
        </nav>
        <nav aria-label="Recursos">
          <strong>Recursos</strong>
          <a href="/herramientas/">IAs</a>
          <a href="/repos/">Repos</a>
          <a href="/aportar/">Contacto</a>
        </nav>
      </div>
      <p>Academia de IA ConectaNex · Fundada por Yinmy Lazaro Carrazana · {anio}</p>
      <p style="font-size:.85rem;margin:.25rem 0 0">Gratuita y abierta. Hecha con Astro.</p>
      <p style="font-size:.85rem;margin:.5rem 0 0"><a href="/privacidad/">Privacidad</a> · <a href="/aportar/">Contacto</a></p>
    </footer>

    <script is:inline>
      document.getElementById('toggle-tema')?.addEventListener('click', function () {
        var actual = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', actual);
        try { localStorage.setItem('tema', actual); } catch (e) {}
      });
    </script>

    <!-- Progreso de estudio (localStorage, sin backend) -->
    <script is:inline>
      (function () {
        window.bibProgreso = {
          load: function () { return window.BIB.get('progreso', '{}'); },
          save: function (m) { window.BIB.set('progreso', m); }
        };
        function paint(btn, on) {
          btn.setAttribute('aria-pressed', on ? 'true' : 'false');
          btn.classList.toggle('marcado', on);
          var ico = btn.querySelector('.marcar-icono');
          var txt = btn.querySelector('.marcar-txt');
          if (ico) ico.textContent = on ? '✓' : '○';
          if (txt) txt.textContent = on ? 'Aprendido' : 'Marcar como aprendido';
        }
        var map = window.bibProgreso.load();
        document.querySelectorAll('.marcar').forEach(function (btn) {
          var k = btn.getAttribute('data-key');
          paint(btn, !!map[k]);
          btn.addEventListener('click', function () {
            var m = window.bibProgreso.load();
            if (m[k]) { delete m[k]; } else { m[k] = true; }
            window.bibProgreso.save(m);
            paint(btn, !!m[k]);
            document.dispatchEvent(new CustomEvent('progreso-cambio'));
          });
        });
      })();
    </script>

    <!-- Favoritos / me gusta (localStorage) -->
    <script is:inline>
      (function () {
        function fload() { return window.BIB.get('favoritos', '{}'); }
        function fsave(m) { window.BIB.set('favoritos', m); }
        function fpaint(b, on) {
          b.setAttribute('aria-pressed', on ? 'true' : 'false');
          b.classList.toggle('fav-on', on);
          var i = b.querySelector('.fav-icono'); if (i) i.textContent = on ? '♥' : '♡';
        }
        var fmap = fload();
        document.querySelectorAll('.fav').forEach(function (b) {
          var k = b.getAttribute('data-key');
          fpaint(b, !!fmap[k]);
          b.addEventListener('click', function (e) {
            e.preventDefault(); e.stopPropagation();
            var m = fload();
            if (m[k]) { delete m[k]; } else { m[k] = true; }
            fsave(m); fpaint(b, !!m[k]);
            document.dispatchEvent(new CustomEvent('progreso-cambio'));
          });
        });
      })();
    </script>

    <!-- Gamificación: XP, niveles, logros, racha, confeti -->
    <script is:inline>
      (function () {
        var RANKS = ['Novato', 'Aprendiz', 'Practicante', 'Avanzado', 'Experto', 'Maestro', 'Leyenda IA'];

        function stats() {
          var prog = window.BIB.get('progreso', '{}');
          var exam = window.BIB.get('examenes', '{}');
          var favs = window.BIB.get('favoritos', '{}');
          var racha = window.BIB.get('racha', '{}');
          var nProg = Object.keys(prog).filter(function (k) { return prog[k]; }).length;
          var passed = 0, perfect = 0;
          Object.keys(exam).forEach(function (k) { var e = exam[k]; if (e && e.passed) { passed++; if (e.score === e.total) perfect++; } });
          var nFav = Object.keys(favs).filter(function (k) { return favs[k]; }).length;
          var dias = racha.dias || 0;
          var xp = nProg * 10 + passed * 50 + nFav * 2;
          var nivel = Math.min(Math.floor(xp / 200), RANKS.length - 1);
          var logros = [
            { id: 'inicio', n: 'Primeros pasos', i: '🌱', ok: nProg >= 1 },
            { id: 'curioso', n: 'Curioso', i: '🔎', ok: nProg >= 5 },
            { id: 'estudioso', n: 'Estudioso', i: '📚', ok: nProg >= 15 },
            { id: 'maestria', n: 'Maestría', i: '🧠', ok: nProg >= 30 },
            { id: 'examen1', n: 'Primer examen', i: '✅', ok: passed >= 1 },
            { id: 'perfecto', n: 'Nota perfecta', i: '💯', ok: perfect >= 1 },
            { id: 'graduado', n: 'Graduado', i: '🎓', ok: passed >= 3 },
            { id: 'fan', n: 'Fan de la IA', i: '❤️', ok: nFav >= 5 },
            { id: 'racha3', n: 'En racha', i: '🔥', ok: dias >= 3 },
            { id: 'racha7', n: 'Imparable', i: '⚡', ok: dias >= 7 }
          ];
          return { xp: xp, nivel: nivel, rank: RANKS[nivel], xpNivel: xp - nivel * 200, xpSube: 200, dias: dias, logros: logros };
        }

        function actualizarRacha() {
          var r = window.BIB.get('racha', '{}');
          var hoy = new Date().toISOString().slice(0, 10);
          if (r.fecha === hoy) return;
          var ayer = new Date(Date.now() - 86400000).toISOString().slice(0, 10);
          r.dias = (r.fecha === ayer) ? (r.dias || 0) + 1 : 1;
          r.fecha = hoy;
          window.BIB.set('racha', r);
        }

        function confetti() {
          var c = document.createElement('canvas');
          c.style.cssText = 'position:fixed;inset:0;pointer-events:none;z-index:9999';
          c.width = innerWidth; c.height = innerHeight; document.body.appendChild(c);
          var ctx = c.getContext('2d'); var P = [];
          var cols = ['#06b6d4', '#57dffe', '#0f172a', '#1f7a3d', '#e0245e', '#ffbb33'];
          for (var i = 0; i < 130; i++) P.push({ x: Math.random() * c.width, y: -20 - Math.random() * c.height * 0.3, r: 4 + Math.random() * 7, vy: 2 + Math.random() * 4, vx: -2 + Math.random() * 4, col: cols[i % cols.length], rot: Math.random() * 6 });
          var t0 = Date.now();
          (function loop() {
            ctx.clearRect(0, 0, c.width, c.height);
            P.forEach(function (p) { p.x += p.vx; p.y += p.vy; p.vy += 0.05; p.rot += 0.1; ctx.save(); ctx.translate(p.x, p.y); ctx.rotate(p.rot); ctx.fillStyle = p.col; ctx.fillRect(-p.r / 2, -p.r / 2, p.r, p.r * 0.6); ctx.restore(); });
            if (Date.now() - t0 < 2600) requestAnimationFrame(loop); else c.remove();
          })();
        }

        function toast(msg) {
          var t = document.createElement('div'); t.className = 'bib-toast'; t.innerHTML = msg;
          document.body.appendChild(t);
          requestAnimationFrame(function () { t.classList.add('show'); });
          setTimeout(function () { t.classList.remove('show'); setTimeout(function () { t.remove(); }, 400); }, 3800);
        }

        function checkLogros(celebrar) {
          var s = stats();
          var prev = window.BIB.get('logros', '[]');
          var ahora = s.logros.filter(function (l) { return l.ok; }).map(function (l) { return l.id; });
          var nuevos = ahora.filter(function (id) { return prev.indexOf(id) === -1; });
          window.BIB.set('logros', ahora);
          if (celebrar && nuevos.length) {
            confetti();
            nuevos.forEach(function (id, idx) {
              var l = s.logros.filter(function (x) { return x.id === id; })[0];
              setTimeout(function () { toast('🏅 ¡Logro desbloqueado! ' + l.i + ' <strong>' + l.n + '</strong>'); }, idx * 600);
            });
          }
        }

        window.bibGami = { stats: stats, confetti: confetti, toast: toast };

        // Inicial: sin celebrar (fija baseline)
        checkLogros(false);
        // Al estudiar (marcar lección/favorito): suma racha y revisa logros
        document.addEventListener('progreso-cambio', function () { actualizarRacha(); checkLogros(true); });
        // Al aprobar un examen: confeti + racha + logros
        document.addEventListener('examen-aprobado', function () { actualizarRacha(); confetti(); checkLogros(true); });
      })();
    </script>

    <!-- Nav consciente de sesión (el sitio es estático: se resuelve en el cliente) -->
    <script>
      import { supabaseBrowser } from '../lib/supabase/client';

      const cont = document.getElementById('nav-auth');

      function link(href: string, text: string, primario = false) {
        const a = document.createElement('a');
        a.href = href;
        a.textContent = text;
        if (primario) a.className = 'btn btn-primario';
        return a;
      }

      function pintar(session: any) {
        if (!cont) return;
        cont.replaceChildren();
        if (session) {
          const nombre = (((session.user.user_metadata || {}).nombre as string) || '').split(' ')[0] || 'alumno';
          const saludo = document.createElement('span');
          saludo.className = 'nav-saludo';
          saludo.textContent = 'Hola, ' + nombre;
          cont.append(saludo, link('/dashboard/', 'Dashboard'), link('/logout', 'Cerrar sesión'));
        } else {
          cont.append(link('/login/', 'Iniciar sesión'), link('/registro/', 'Registrarse', true));
        }
      }

      supabaseBrowser.auth.getSession().then(({ data }) => pintar(data.session));
      supabaseBrowser.auth.onAuthStateChange((_e, session) => pintar(session));
    </script>
  </body>
</html>
